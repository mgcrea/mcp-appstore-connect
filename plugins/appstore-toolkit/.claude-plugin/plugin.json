{
  "name": "appstore-toolkit",
  "displayName": "App Store toolkit",
  "description": "Prepare an Xcode app for the App Store: write the CHANGELOG entry and every App Store Connect metadata field, and round-trip the listing through App Store Connect.",
  "version": "0.1.0",
  "author": {
    "name": "Olivier Louvignes",
    "url": "https://github.com/mgcrea"
  },
  "homepage": "https://github.com/mgcrea/mcp-appstore-connect",
  "repository": "https://github.com/mgcrea/mcp-appstore-connect",
  "license": "MIT",
  "keywords": [
    "app-store",
    "app-store-connect",
    "fastlane",
    "changelog",
    "release",
    "ios",
    "macos"
  ],
  "mcpServers": {
    "appstore-connect": {
      "command": "npx",
      "args": ["-y", "@mgcrea/mcp-appstore-connect"],
      "env": {
        "APP_STORE_CONNECT_KEY_ID": "${APP_STORE_CONNECT_KEY_ID}",
        "APP_STORE_CONNECT_ISSUER_ID": "${APP_STORE_CONNECT_ISSUER_ID}",
        "APP_STORE_CONNECT_P8_PATH": "${APP_STORE_CONNECT_P8_PATH}",
        "APP_STORE_CONNECT_VENDOR_NUMBER": "${APP_STORE_CONNECT_VENDOR_NUMBER}",
        "APP_STORE_CONNECT_ALLOW_WRITES": "${APP_STORE_CONNECT_ALLOW_WRITES}"
      }
    }
  }
}
