# App Store Connect API key. Create one in App Store Connect:
#   Users and Access → Integrations → Keys → App Store Connect API → (+)
# You get three things: an Issuer ID, a Key ID, and a one-time `.p8` download.

# The 10-character Key ID shown next to the key.
APP_STORE_CONNECT_KEY_ID=XXXXXXXXXX

# The Issuer ID (a UUID) shown at the top of the Keys page.
APP_STORE_CONNECT_ISSUER_ID=00000000-0000-0000-0000-000000000000

# ── Private key: set exactly ONE of the two ──────────────────────────────────
# Path to the AuthKey_XXXXXXXXXX.p8 you downloaded (Apple only lets you download
# it once — keep it safe, it is git-ignored here).
APP_STORE_CONNECT_P8_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8

# ...or paste the PEM contents inline instead (handy for Docker / CI secrets).
# APP_STORE_CONNECT_P8="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ── Reports (optional) ───────────────────────────────────────────────────────
# Vendor number for sales & finance reports. Find it under Payments and
# Financial Reports in App Store Connect. Only the report tools need it.
APP_STORE_CONNECT_VENDOR_NUMBER=

# ── Safety ───────────────────────────────────────────────────────────────────
# Set to 1 to register the WRITE tools (create version, edit metadata, manage
# testers, register devices, bundle-id capabilities). Off by default: only read
# tools exist. Destructive tools (remove tester, disable capability) additionally
# require an explicit `confirm: true` on every call.
APP_STORE_CONNECT_ALLOW_WRITES=

# ── Optional tuning ──────────────────────────────────────────────────────────
# Retry budget for 401 / 429 / 5xx responses. Defaults to 3.
APP_STORE_CONNECT_MAX_RETRIES=3

# JWT lifetime in seconds. Apple caps it at 1200 (20 min); defaults to 1140.
APP_STORE_CONNECT_TOKEN_TTL_SECONDS=1140

# Where export_listing writes the listing tree, relative to the repo root.
# Defaults to fastlane/metadata — the layout `fastlane deliver` reads, which is
# why it is the default. Set it to e.g. AppStore if you keep it elsewhere; use
# "." for the repo root. apply_listing ignores this and finds the tree from the
# .listing.json you pass it.
APP_STORE_CONNECT_METADATA_ROOT=

# Set to 1 to log debug output to stderr.
APP_STORE_CONNECT_DEBUG=
